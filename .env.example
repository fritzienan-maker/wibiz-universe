# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_BASE_URL=https://academy.wibiz.ai

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/wibiz_academy

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# ─── Admin seed (used ONCE by: npx tsx scripts/seed-admin.ts) ─────────────────
ADMIN_EMAIL=admin@wibiz.ai
ADMIN_PASSWORD=change-before-seeding

# ─── GHL (GoHighLevel) ────────────────────────────────────────────────────────
# ROTATE IMMEDIATELY if these values were ever committed or shared
GHL_API_KEY=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GHL_LOCATION_ID=your-ghl-location-id
GHL_WEBHOOK_SECRET=change-this-to-a-shared-secret

# ─── DocuSeal (formal document signing) ──────────────────────────────────────
# Used for: Client Success Manual, HSKD Liability Sign-Off, Operator Conduct Declaration
# Get from: app.docuseal.com → Settings → API
DOCUSEAL_API_TOKEN=your-docuseal-api-token-here

# ─── Phase 2+ (leave blank) ───────────────────────────────────────────────────
# JOTFORM_WEBHOOK_SECRET=
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
